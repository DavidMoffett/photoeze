    document.getElementById('drop-text').textContent = selectedFiles.length + ' photo' + (selectedFiles.length !== 1 ? 's' : '') + ' ready';
  });

  async function compressImage(file) {
    return new Promise(resolve => {
      const img = new Image();
      const url = URL.createObjectURL(file);
      img.onload = () => {
        URL.revokeObjectURL(url);
        const canvas = document.createElement('canvas');
        let { width, height } = img;
        const maxDim = 3000;
        if (width > maxDim || height > maxDim) {
          const ratio = Math.min(maxDim / width, maxDim / height);
          width = Math.round(width * ratio);
          height = Math.round(height * ratio);
        }
        canvas.width = width;
        canvas.height = height;
        canvas.getContext('2d').drawImage(img, 0, 0, width, height);
        canvas.toBlob(blob => resolve(blob), 'image/jpeg', 0.85);
      };
      img.onerror = () => resolve(file);
      img.src = url;
    });
  }

  // ── CREATE GALLERY ──
  async function createGallery() {
    const name = document.getElementById('ng-name').value.trim();
    const price = parseFloat(document.getElementById('ng-price').value) || 10;
    const errEl = document.getElementById('ng-error');
    errEl.style.display = 'none';
    if (!name) { errEl.textContent = 'Please enter a gallery name.'; errEl.style.display = 'block'; return; }

    const btn = document.getElementById('btn-create-gallery');
    btn.disabled = true;
    btn.textContent = 'Creating…';

    const slug = name.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '') + '-' + Date.now();
    const { data: gallery, error } = await sb.from('galleries').insert({ photographer_id: currentUser.id, name, slug, price_nzd: price }).select().single();

    if (error) {
      errEl.textContent = error.message;
      errEl.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Create Gallery';
      return;
    }

    if (selectedFiles.length > 0) {
      const progress = document.getElementById('upload-progress');
      const fill = document.getElementById('upload-fill');
      const txt = document.getElementById('upload-text');
      progress.style.display = 'block';

      for (let i = 0; i < selectedFiles.length; i++) {
        const file = selectedFiles[i];
        txt.textContent = 'Compressing ' + (i + 1) + ' of ' + selectedFiles.length + '…';
        try {
          const compressed = await compressImage(file);
          const key = currentUser.id + '/' + gallery.id + '/' + Date.now() + '-' + file.name.replace(/[^a-zA-Z0-9._-]/g, '_');
          txt.textContent = 'Uploading ' + (i + 1) + ' of ' + selectedFiles.length + '…';
          const { error: uploadError } = await sb.storage.from('photos-original').upload(key, compressed, { contentType: 'image/jpeg' });
          if (!uploadError) {
            await sb.from('photos').insert({ gallery_id: gallery.id, photographer_id: currentUser.id, filename: file.name, storage_path: key, size_bytes: compressed.size });
          }
        } catch (e) { console.error('Upload error:', e); }
        fill.style.width = Math.round(((i + 1) / selectedFiles.length) * 100) + '%';
      }

      txt.textContent = selectedFiles.length + ' photos uploaded ✓';
      setTimeout(() => { progress.style.display = 'none'; fill.style.width = '0%'; }, 2000);
    }

    btn.disabled = false;
    btn.textContent = 'Create Gallery';
    selectedFiles = [];
    document.getElementById('ng-name').value = '';
    document.getElementById('ng-price').value = '';
    document.getElementById('drop-text').textContent = 'Drop photos here or click to browse';
    closeModal('modal-new-gallery');
    loadGalleries();
  }

