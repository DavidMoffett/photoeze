  // ── GALLERIES ──
  async function loadGalleries() {
    const grid = document.getElementById('gallery-grid');
    grid.innerHTML = '<div class="loading"><div class="spinner"></div> Loading galleries…</div>';

    const { data: galleries, error } = await sb.from('galleries').select('*, photos(count)').eq('photographer_id', currentUser.id).order('created_at', { ascending: false });

    if (error) { grid.innerHTML = '<div class="loading">Error loading galleries.</div>'; return; }

    if (galleries?.length > 0) {
      document.getElementById('card-create').classList.add('done');
      document.getElementById('card-create-sub').textContent = galleries.length + ' created';
      if (galleries.some(g => g.is_published)) {
        document.getElementById('card-share').classList.add('done');
        document.getElementById('card-share-sub').textContent = 'Gallery is live';
      }
    }

    let html = '';
    if (galleries?.length > 0) {
      galleries.forEach(g => {
        const count = g.photos?.[0]?.count || 0;
        html += '<div class="gallery-card">' +
          '<div class="gallery-thumb"><div class="gallery-thumb-placeholder">📷</div>' +
          '<div class="gallery-thumb-count">' + count + ' photo' + (count !== 1 ? 's' : '') + '</div></div>' +
          '<div class="gallery-info">' +
          '<div class="gallery-name">' + escHtml(g.name) + '</div>' +
          '<div class="gallery-meta"><span>$' + Number(g.price_nzd).toFixed(2) + ' NZD</span><span>' + (g.is_published ? '🟢 Live' : '⚪ Draft') + '</span></div>' +
          '<div class="gallery-actions">' +
          '<button class="btn-sm primary">View</button>' +
          '<button class="btn-sm" onclick="copyShareLink(\'' + g.slug + '\')">Share</button>' +
          '<button class="btn-sm" onclick="togglePublish(\'' + g.id + '\',' + g.is_published + ')">' + (g.is_published ? 'Unpublish' : 'Publish') + '</button>' +
          '<button class="btn-sm danger" onclick="deleteGallery(\'' + g.id + '\',\'' + escHtml(g.name) + '\')">Delete</button>' +
          '</div></div></div>';
      });
    } else {
      html = '<div class="empty-state"><div class="empty-state-icon">🖼️</div><div class="empty-state-title">No galleries yet</div><div class="empty-state-text">Click Create Gallery to get started.</div></div>';
    }

    grid.innerHTML = html;
  }

  async function togglePublish(id, current) {
    await sb.from('galleries').update({ is_published: !current }).eq('id', id);
    loadGalleries();
  }

  async function deleteGallery(id, name) {
    if (!confirm('Delete "' + name + '"? This cannot be undone.')) return;
    await sb.from('photos').delete().eq('gallery_id', id);
    await sb.from('galleries').delete().eq('id', id);
