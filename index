    const { count: orderCount } = await sb.from('orders').select('*', { count: 'exact', head: true }).eq('photographer_id', currentUser.id).eq('status', 'paid');
    document.getElementById('stat-visitors').textContent = visitors?.length || 0;
    document.getElementById('stat-galleries').textContent = galleryCount || 0;
