    body.innerHTML = visitors.map(v => '<div class="table-row visitors-cols"><div><div class="visitor-name">' + escHtml(v.full_name) + '</div></div><div style="color:var(--grey-400);font-size:13px">' + escHtml(v.email) + '</div><div style="font-size:13px">' + escHtml(v.galleries?.name || '—') + '</div><div style="font-size:13px;color:var(--grey-400)">' + formatDate(v.created_at) + '</div></div>').join('');
  }

  // ── SALES ──
  async function loadSales() {
    const body = document.getElementById('orders-body');
    body.innerHTML = '<div class="loading"><div class="spinner"></div> Loading…</div>';
    const { data: orders } = await sb.from('orders').select('*, galleries(name)').eq('photographer_id', currentUser.id).order('created_at', { ascending: false });
    const paid = (orders || []).filter(o => o.status === 'paid');
    const revenue = paid.reduce((sum, o) => sum + Number(o.amount_nzd), 0);
    document.getElementById('stat-revenue').textContent = '$' + revenue.toFixed(2);
    document.getElementById('stat-orders').textContent = paid.length;
    document.getElementById('stat-avg').textContent = '$' + (paid.length ? (revenue / paid.length).toFixed(2) : '0.00');
    if (!orders?.length) {
      body.innerHTML = '<div class="empty-state"><div class="empty-state-icon">💰</div><div class="empty-state-title">No sales yet</div><div class="empty-state-text">Connect Stripe and share your gallery to start selling.</div></div>';
      return;
    }
    body.innerHTML = orders.map(o => '<div class="table-row sales-cols"><div><div class="visitor-name">' + escHtml(o.buyer_name) + '</div></div><div style="font-size:13px;color:var(--grey-400)">' + escHtml(o.galleries?.name || '—') + '</div><div class="amount">$' + Number(o.amount_nzd).toFixed(2) + '</div><div style="font-size:13px;color:var(--grey-400)">' + formatDate(o.created_at) + '</div><div><span class="status-badge status-' + o.status + '">' + o.status + '</span></div></div>').join('');
  }

  // ── WATERMARK ──
  async function loadWatermarkSettings() {
    const { data } = await sb.from('watermark_settings').select('*').eq('id', currentUser.id).single();
    if (data) {
      document.getElementById('wm-text').value = data.text || '';
      document.getElementById('wm-position').value = data.position || 'centre';
      document.getElementById('wm-opacity').value = data.opacity || 35;
      updateWatermarkPreview();
    }
  }

  async function saveWatermarkSettings() {
    const settings = { id: currentUser.id, text: document.getElementById('wm-text').value, position: document.getElementById('wm-position').value, opacity: parseInt(document.getElementById('wm-opacity').value) };
    await sb.from('watermark_settings').upsert(settings);
    document.getElementById('card-watermark').classList.add('done');
    alert('Watermark saved.');
  }

  function updateWatermarkPreview() {
    const text = document.getElementById('wm-text').value || '© Your Name';
    const opacity = (document.getElementById('wm-opacity').value || 35) / 100;
    const el = document.getElementById('wm-preview');
    el.textContent = text;
    el.style.color = 'rgba(255,255,255,' + opacity + ')';
  }

  function copyGalleryUrl() {
    navigator.clipboard.writeText('https://photoeze.netlify.app/' + (currentPhotographer?.slug || 'your-slug'));
    alert('Link copied!');
  }

  function escHtml(str) {
    if (!str) return '';
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function formatDate(iso) {
    if (!iso) return '—';
    return new Date(iso).toLocaleDateString('en-NZ', { day: 'numeric', month: 'short', year: 'numeric' });
  }
</script>
</body>
</html>

